# SQL Server
MSSQL_SA_PASSWORD=YourStrong@Passw0rd
DB_NAME=HrPortalDb

# Connection string (used by backend container)
ConnectionStrings__DefaultConnection=Server=sqlserver,1433;Database=HrPortalDb;User Id=sa;Password=YourStrong@Passw0rd;TrustServerCertificate=True;

# JWT
Jwt__Secret=YourSuperSecretKeyAtLeast32CharactersLong!
Jwt__Issuer=HrPortal
Jwt__Audience=HrPortalUsers
Jwt__AccessTokenMinutes=15
Jwt__RefreshTokenDays=7

# CORS
CORS__AllowedOrigins=http://localhost:3000

# File upload
FileUpload__MaxSizeMb=10

# Frontend (Vite build arg)
VITE_API_URL=http://localhost:5000
